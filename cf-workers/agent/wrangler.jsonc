{
  "name": "codeops-agent",
  "main": "src/index.ts",
  "compatibility_date": "2025-01-01",
  "compatibility_flags": ["nodejs_compat"],

  "services": [
    {
      "binding": "A2A_FEDERATION",
      "service": "codeops-a2a"
    }
  ],

  "ai": {
    "binding": "AI"
  },

  // CF AI Gateway route schema — set these to use the route schema for /infer.
  // Leave empty to fall back to env.AI.run() directly (AI binding above).
  // CF_AIG_TOKEN: create at dash.cloudflare.com → AI Gateway → {gateway} → Settings → API tokens
  "vars": {
    "CF_ACCOUNT_ID": "",
    "CF_GATEWAY_ID": "default",
    "CF_AIG_TOKEN": ""
  },

  "durable_objects": {
    "bindings": [
      {
        "name": "CODEOPS_MCP_AGENT",
        "class_name": "CodeOpsMcpAgent"
      }
    ]
  },

  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["CodeOpsMcpAgent"]
    }
  ]
}
