# =============================================================================
# VOLY Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# --- LLM Providers ---
# BYOK: with `ai_gateway.byok_enabled: true` in voly.yaml the keys for
# anthropic / openai / google / deepseek live in CF Secrets Store and are
# resolved by the AI Gateway — these env keys are then NOT needed.
# See docs/backend/ai-gateway.md § BYOK (Store Keys).
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com

GOOGLE_API_KEY=
GOOGLE_BASE_URL=https://generativelanguage.googleapis.com

OLLAMA_HOST=http://localhost:11434

# --- DeepSeek (OpenAI-compatible, best for code generation) ---
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# --- OpenCode Go (agentic code executor via OpenCode platform) ---
OPENCODE_API_KEY=
OPENCODE_BASE_URL=https://opencode.ai/zen/go/v1

# --- OpenCode Zen (multi-provider gateway: Claude/GPT/Gemini/DeepSeek/MiMo/Kimi/etc.) ---
# Available models: claude-sonnet-4-6, deepseek-v4-flash, gpt-5.4, kimi-k2.5, mimo-v2.5, etc.
OPENCODE_ZEN_BASE_URL=https://opencode.ai/zen/v1

# --- Cursor Agent (default executor for code implementation) ---
CURSOR_API_KEY=
# CURSOR_MODEL=composer-2.5-fast

# --- MiMo (xiaomimimo — cheap batch generation, code snippets, configs) ---
# Available models: mimo-v2.5, mimo-v2.5-pro, mimo-v2-omni
MIMO_API_KEY=
MIMO_BASE_URL_OPENAI=https://token-plan-sgp.xiaomimimo.com/v1
MIMO_BASE_URL_ANTHROPIC=https://token-plan-sgp.xiaomimimo.com/anthropic

# --- VOLY control (optional) ---
# cwd по умолчанию для executor-ов (или default_cwd в voly.yaml).
# VOLY_PROJECT_CWD=/path/to/target/project
# Plan gates (Rung B) — см. docs/backend/config.md.
# VOLY_PLAN_ENABLED=true
# VOLY_PLAN_MODE=active
# Пул потоков для POST /api/run (web/routes/run.py).
# VOLY_RUN_POOL_WORKERS=16
# Hybrid multi-agent: implement-роли через executor+cwd (a2a.hybrid_code_gen).
# VOLY_A2A_HYBRID=true
# Принудительно включить BYOK (ai_gateway.byok_enabled).
# VOLY_BYOK=1

# --- VOLY Cloud link (optional) — local runs → shared org history ---
# Отчёт о завершённых локальных ранах в control plane (метаданные, не файлы).
# Токен — tenant edge JWT из манифеста организации. См. docs/backend/config.md.
# VOLY_CLOUD_ENABLED=true
# VOLY_CLOUD_URL=http://127.0.0.1:7790
# VOLY_CLOUD_TENANT_ID=...
# VOLY_CLOUD_TOKEN=...
# VOLY_CLOUD_USER_ID=...
# Проще: `voly cloud login` — сохранит device-линк в .voly/cloud.json
# (путь можно переопределить):
# VOLY_CLOUD_LINK_FILE=.voly/cloud.json

# --- Web UI auth (optional — default: disabled, localhost-only open API) ---
# Open-core self-host lock: local JWT (no external IdP).
# VOLY_AUTH_ENABLED=true
# VOLY_AUTH_PROVIDER=local
# VOLY_JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
# VOLY_AUTH_USERS=admin:change-me
# VOLY_AUTH_CORS=http://localhost:7788,http://localhost:5173
#
# Optional SSO (Clerk) — team/hosted oriented, NOT open-core default.
# May move to a separate Team package. See CONTRIBUTING.md.
# VOLY_AUTH_PROVIDER=clerk
# CLERK_PUBLISHABLE_KEY=pk_test_...
# CLERK_SECRET_KEY=sk_test_...
# CLERK_ISSUER=https://your-instance.clerk.accounts.dev
# CLERK_JWKS_URL=https://your-instance.clerk.accounts.dev/.well-known/jwks.json

# --- A2A multi-agent (optional) ---
# Bearer-токен для federation-запросов к A2A/agent воркерам (a2a.token).
# VOLY_A2A_TOKEN=...
# Скрыть провайдеров из tier-пула суб-агентов (напр. если кончились кредиты).
# VOLY_A2A_EXCLUDE_PROVIDERS=anthropic,openai

# --- OmniRoute (optional — self-hosted OpenAI-compat AI gateway, 237+ providers) ---
# Opt-in upstream: select provider `omniroute` explicitly (not in default chains).
# Start OmniRoute locally (`omniroute` / docker), then point VOLY at it.
OMNIROUTE_BASE_URL=http://localhost:20128
# OMNIROUTE_API_KEY=            # only if your OmniRoute instance requires auth
# OMNIROUTE_COMBO=              # optional routing strategy → sent as X-Omni-Combo

# --- Cloudflare AI Gateway (optional) ---
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_AI_GATEWAY_ID=default
CLOUDFLARE_API_TOKEN=
# Authenticated gateway token (Dashboard → AI Gateway → Settings → Authentication).
# Required for BYOK and dynamic routing; also VOLY_BYOK=1 to force BYOK on.
# CF_AIG_TOKEN=
# Gateway transport: rest (default, api.cloudflare.com AI REST API) | compat
# (deprecated gateway.ai.cloudflare.com host — escape hatch).
# VOLY_CF_GATEWAY_API=rest

# --- Cloudflare Workers (optional — deploy cf-workers/* to enable each service) ---
# CF_WORKER_AGENT_URL=https://agent.voly.codes
# CF_WORKER_A2A_URL=https://a2a.voly.codes
# CF_WORKER_MEMORY_URL=https://memory.voly.codes
# CF_WORKER_SPEND_URL=https://spend.voly.codes
# CF_WORKER_AGUI_URL=https://spend.voly.codes
# Official hosted VOLY catalog & marketplace — uncomment to use them instead of
# deploying your own from cf-workers/ (opt-in; catalog/skill queries will go to
# these workers). `voly setup` can write these for you.
# CF_WORKER_MARKETPLACE_URL=https://marketplace.voly.codes
# CF_WORKER_CATALOG_URL=https://catalog.voly.codes

# --- Cloudflare Pipelines (telemetry ingest) ---
# Native Pipelines beta may be unavailable (Forbidden). Use telemetry Worker:
#   cd cf-workers/telemetry && npm install && npx wrangler deploy
CF_PIPELINE_TELEMETRY_NAME=voly-telemetry
CF_PIPELINE_TELEMETRY_ENDPOINT=https://voly-telemetry.<subdomain>.workers.dev/ingest
CF_WORKER_TELEMETRY_URL=https://voly-telemetry.<subdomain>.workers.dev

# --- Cloudflare R2 (direct telemetry fallback) ---
# CF_R2_ENDPOINT=
# CF_R2_BUCKET_TELEMETRY=voly-telemetry
# CF_R2_ACCESS_KEY_ID=
# CF_R2_SECRET_ACCESS_KEY=

# --- RTK (Rust Token Killer) ---
RTK_REPO_URL=https://github.com/rtk-ai/rtk

# --- GitHub Token (for MCP GitHub server) ---
GITHUB_TOKEN=

# --- GitLab Token (for MCP GitLab server) ---
GITLAB_TOKEN=

# --- Database (for MCP PostgreSQL server) ---
DATABASE_URL=

# Порты сервисов (`voly serve` 9202, `voly ui` 7788, `voly a2a` 9100) задаются
# флагом `--port`, не через env.

# --- Headroom (optional overrides) ---
# HEADROOM_SAVINGS_PROFILE=agent-90
# HEADROOM_MEMORY=0
# HEADROOM_CODE_GRAPH=0

# --- pxpipe (optional Claude Code token-saving proxy) ---
# Start sidecar: `voly pxpipe start`
# Rendered PNGs are saved locally under .voly/pxpipe/images/<task_id>/.
# VOLY_PXPIPE_ENABLED=true
# VOLY_PXPIPE_PORT=47821
# VOLY_PXPIPE_MODELS=claude-fable-5,gpt-5.6
# VOLY_PXPIPE_AUTO_START=false
# VOLY_PXPIPE_OVERRIDE_BASE_URL=false
